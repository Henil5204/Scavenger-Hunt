<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        Theme is Material3 NoActionBar — login screen draws its own header
        inside a card, and the other screens add an explicit Toolbar in
        their layouts. Doing it that way means the login screen can have
        a full-bleed background.
    -->
    <style name="Base.Theme.ScavengerHunt" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>

        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnSecondary">@color/text_on_brand</item>

        <item name="android:statusBarColor">@color/brand_primary_dark</item>
        <item name="android:windowBackground">@color/bg_app</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Theme.ScavengerHunt" parent="Base.Theme.ScavengerHunt" />

    <!-- Reusable styles so I'm not copy-pasting the same 6 attributes everywhere -->

    <style name="App.Card" parent="">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
    </style>

    <style name="App.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_on_brand</item>
    </style>

    <style name="App.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
    </style>

    <style name="App.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="hintTextColor">@color/brand_primary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

</resources>
