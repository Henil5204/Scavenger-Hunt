<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Picked these after spending way too long on coolors.io.
        Going for warm-and-modern instead of the default purple. Teal feels
        outdoorsy/explorery (which fits "scavenger hunt") and coral pops on top
        without clashing.
    -->

    <!-- brand -->
    <color name="brand_primary">#0F766E</color>          <!-- deep teal -->
    <color name="brand_primary_dark">#0B5751</color>     <!-- status bar -->
    <color name="brand_primary_light">#14B8A6</color>    <!-- hover/pressed accents -->
    <color name="brand_accent">#F97316</color>           <!-- coral, used on FAB + highlights -->
    <color name="brand_accent_dark">#C2410C</color>

    <!-- surfaces -->
    <color name="bg_app">#FFFBF7</color>                 <!-- warm off-white app bg -->
    <color name="bg_card">#FFFFFF</color>
    <color name="bg_input">#F3F4F6</color>               <!-- subtle filled-input grey -->

    <!-- text -->
    <color name="text_primary">#1F2937</color>
    <color name="text_secondary">#6B7280</color>
    <color name="text_hint">#9CA3AF</color>
    <color name="text_on_brand">#FFFFFF</color>

    <!-- semantic -->
    <color name="success">#16A34A</color>                <!-- "DONE" green -->
    <color name="success_soft">#DCFCE7</color>           <!-- pill bg behind DONE -->
    <color name="divider">#E5E7EB</color>

    <!-- legacy android defaults — keeping so the launcher icons still build -->
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- legacy alias from before the teal redesign — kept so anything still
         pointing at @color/purple resolves to the new brand colour instead
         of failing to link -->
    <color name="purple">#0F766E</color>
</resources>
