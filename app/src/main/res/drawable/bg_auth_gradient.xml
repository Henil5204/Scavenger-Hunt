<?xml version="1.0" encoding="utf-8"?>
<!-- gradient backdrop for the login + signup screens.
     teal at the top fading to a softer lighter teal at the bottom.
     I tried a single solid color first and it looked flat — gradient gives
     it a bit of depth without being loud. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="@color/brand_primary"
        android:endColor="@color/brand_primary_light"
        android:type="linear" />
</shape>
