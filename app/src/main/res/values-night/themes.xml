<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Dark mode. Material3 DayNight handles most of it; just nudge the
         status bar to a deeper teal so it doesn't blend with system UI. -->
    <style name="Base.Theme.ScavengerHunt" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary_light</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="android:statusBarColor">@color/brand_primary_dark</item>
    </style>

    <style name="Theme.ScavengerHunt" parent="Base.Theme.ScavengerHunt" />
</resources>
