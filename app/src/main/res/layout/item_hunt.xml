<?xml version="1.0" encoding="utf-8"?>
<!--
    One row in the list.

    Layout:
       ┌──────────────────────────────────────────┐
       │ Big bold name              ⭐⭐⭐⭐½       │
       │ 📍 Address, City                         │
       │ 🏷 tag                              ✓     │
       └──────────────────────────────────────────┘
    The check on the right only shows when hunt.completed == true.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:rippleColor="@color/brand_primary_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- name + rating row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/huntName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <RatingBar
                android:id="@+id/huntRating"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:isIndicator="true"
                android:numStars="5"
                android:stepSize="0.5" />
        </LinearLayout>

        <!-- location line -->
        <TextView
            android:id="@+id/huntLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:drawableStart="@drawable/ic_location_18"
            android:drawablePadding="6dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- tag chip + done check -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/huntTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_chip"
                android:drawableStart="@drawable/ic_tag_14"
                android:drawablePadding="4dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/brand_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/huntDone"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/completed_badge"
                android:src="@drawable/ic_check_circle_24"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
